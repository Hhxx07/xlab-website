# ===========================================================================
# .env.example — 环境变量模板
#
# 使用方法：
#   1. 复制此文件为 .env：  cp .env.example .env
#   2. 修改 .env 中的占位符为真实值
#   3. 启动服务：            docker compose up -d
#
# .env 已在 .gitignore 中忽略，不会被提交到版本控制。
# ===========================================================================

# ---- 应用环境 ----
# development → 开发模式（热重载，打印验证链接到控制台）
# production  → 生产模式
APP_ENV=development

# HTTP 服务端口
PORT=8080

# ---- 数据库 & 缓存 ----
DATABASE_URL=postgres://app:app@postgres:5432/app?sslmode=disable
REDIS_URL=redis://redis:6379

# ---- 安全 ----
# JWT 签名密钥（生产环境务必更换为随机字符串）
JWT_SECRET=change-me-to-a-random-secret

# Session Token 有效期（小时），默认 168 = 7 天
SESSION_TTL_HOURS=168

# ---- 前端地址 ----
# 本地开发：http://localhost:5173
# 生产部署：https://你的域名.com
FRONTEND_URL=http://localhost:5173

# ---- 邮件 SMTP（发送邮箱验证码 / Magic Link） ----
# QQ邮箱示例（需要开启 SMTP 服务，使用授权码而非登录密码）：
#   SMTP_HOST=smtp.qq.com
#   SMTP_PORT=587
#   SMTP_USER=你的QQ号@qq.com
#   SMTP_PASSWORD=你的授权码
#   SMTP_FROM=你的QQ号@qq.com
#
# 163邮箱示例：
#   SMTP_HOST=smtp.163.com
#   SMTP_PORT=587
#   SMTP_USER=你的邮箱@163.com
#   SMTP_PASSWORD=你的授权码
#   SMTP_FROM=你的邮箱@163.com
#
# SMTP_HOST 和 SMTP_USER 都非空时才会真实发送邮件（否则打印到控制台）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- GitHub OAuth（可选，暂未使用） ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback
